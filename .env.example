# ─────────────────────────────────────────────
# iteratr — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────
# Get from: console.cloud.google.com
# Create project → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── GitHub OAuth ──────────────────────────────
# Get from: github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── Supabase ──────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Upstash Redis (Optional - recommended for rate limiting) ──
# Used for fast per-user daily quotas & global generation protection.
# Create at: upstash.com → Redis
UPSTASH_REDIS_REST_URL=https://your-upstash-rest-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here

# ── Gemini API ────────────────────────────────
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── RAG / pgvector (Optional) ──────────────────
# Used by /api/knowledge/inject to securely add documents to `knowledge_base`.
# Generate with: openssl rand -base64 32
RAG_ADMIN_KEY=your_rag_admin_key_here

# ── Judge0 (Optional but recommended for real code execution) ──
# Use RapidAPI Judge0 CE or your self-hosted Judge0 CE endpoint
# If not set, code execution falls back to AI-only evaluation.
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_API_KEY=your_judge0_api_key_here

# ── WebSocket Server (Real-Time Interview) ─────────────────────
# The URL your Next.js frontend uses to connect to the WS server.
# In development: http://localhost:3001
# In production:  https://ws.yourdomain.com  (or the server's public IP/URL)
NEXT_PUBLIC_WS_URL=http://localhost:3001
WS_PORT=3001

# ── Stripe — Payments ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
